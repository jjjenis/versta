@model IReadOnlyCollection<Domain.Entities.Order>

@{
    ViewData["Title"] = "Заказы";
}

<div class="d-flex align-items-center justify-content-between gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">Заказы на доставку</h1>
        <p class="text-muted mb-0">Все созданные заявки на забор и доставку груза.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Создать заказ</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">
        Заказов пока нет. Создайте первый заказ на доставку.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
            <tr>
                <th>Номер заказа</th>
                <th>Отправитель</th>
                <th>Получатель</th>
                <th>Вес</th>
                <th>Дата забора</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var order in Model)
            {
                <tr class="clickable-row" role="link" tabindex="0" data-href="@Url.Action("Details", new { id = order.Id })">
                    <td class="fw-semibold">@order.OrderNumber</td>
                    <td>@order.SenderCity, @order.SenderAddress</td>
                    <td>@order.RecipientCity, @order.RecipientAddress</td>
                    <td>@order.CargoWeight кг</td>
                    <td>@order.PickupDate.ToString("dd.MM.yyyy HH:mm")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script>
        document.querySelectorAll('.clickable-row').forEach(row => {
            const open = () => window.location.href = row.dataset.href;
            row.addEventListener('click', open);
            row.addEventListener('keydown', event => {
                if (event.key === 'Enter' || event.key === ' ') {
                    event.preventDefault();
                    open();
                }
            });
        });
    </script>
}
