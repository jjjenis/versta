@model Presentation.ViewModels.Orders.CreateOrderViewModel

@{
    ViewData["Title"] = "Создать заказ";
}

<div class="mb-4">
    <h1 class="h3 mb-1">Создать заказ</h1>
    <p class="text-muted mb-0">Заполните данные отправителя, получателя и груза.</p>
</div>

<form asp-action="Create" method="post" class="order-form">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="SenderCity" class="form-label"></label>
            <input asp-for="SenderCity" class="form-control" />
            <span asp-validation-for="SenderCity" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="SenderAddress" class="form-label"></label>
            <input asp-for="SenderAddress" class="form-control" />
            <span asp-validation-for="SenderAddress" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="RecipientCity" class="form-label"></label>
            <input asp-for="RecipientCity" class="form-control" />
            <span asp-validation-for="RecipientCity" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="RecipientAddress" class="form-label"></label>
            <input asp-for="RecipientAddress" class="form-control" />
            <span asp-validation-for="RecipientAddress" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="CargoWeight" class="form-label"></label>
            <input asp-for="CargoWeight" class="form-control" min="1" type="number" />
            <span asp-validation-for="CargoWeight" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="PickupDate" class="form-label"></label>
            <input asp-for="PickupDate" class="form-control" type="datetime-local" />
            <span asp-validation-for="PickupDate" class="text-danger"></span>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a class="btn btn-outline-secondary" asp-action="Index">К списку</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
